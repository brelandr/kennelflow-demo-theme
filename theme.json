{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#0D9488",
					"name": "Primary Teal"
				},
				{
					"slug": "accent",
					"color": "#1E3A5F",
					"name": "Accent Navy"
				},
				{
					"slug": "surface",
					"color": "#FFFFFF",
					"name": "Surface"
				},
				{
					"slug": "muted",
					"color": "#64748B",
					"name": "Muted Text"
				},
				{
					"slug": "background",
					"color": "#F8FAFC",
					"name": "Background"
				}
			]
